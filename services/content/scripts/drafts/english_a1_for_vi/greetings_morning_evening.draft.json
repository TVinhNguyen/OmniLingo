      "prompt": {
        "text": {
          "vi": "Từ \"morning\" có nghĩa là gì trong tiếng Việt?"
        }
      },
      "choices": [
        "buổi sáng",
        "bình minh",
        "ban ngày",
        "chào"
      ],
      "answer": 0,
      "explanation": {
        "vi": "Từ \"morning\" có nghĩa là \"buổi sáng\" trong tiếng Việt, dùng để chỉ khoảng thời gian từ lúc mặt trời mọc đến trưa. Ví dụ: \"Good morning!\" có nghĩa là \"Chào buổi sáng!\""
      },
