# grammar-service environment variables
ENV=development
PORT=3006
VERSION=dev

# MongoDB (grammar_db)
MONGO_URI=mongodb://omnilingo:omnilingo_dev@localhost:27017/grammar_db?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9094
KAFKA_ENABLED=false
KAFKA_GROUP_ID=grammar-service

# Identity service (for JWKS)
IDENTITY_SERVICE_URL=http://localhost:3001

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

LOG_LEVEL=info

# Drill generation
DRILL_MAX_GENERATE=10
