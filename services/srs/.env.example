# srs-service environment variables
ENV=development
PORT=3005
VERSION=dev

# PostgreSQL (srs_db)
DATABASE_URL=postgres://omnilingo:omnilingo_dev@localhost:5432/srs_db?sslmode=disable

# Redis
REDIS_URL=redis://127.0.0.1:6379/

# Kafka
KAFKA_BROKERS=localhost:9094
KAFKA_ENABLED=false
KAFKA_GROUP_ID=srs-service

# Identity service (for JWKS)
IDENTITY_SERVICE_URL=http://localhost:3001

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

LOG_LEVEL=info
