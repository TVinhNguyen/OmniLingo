# identity-service — Development environment
ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://omnilingo:omnilingo_dev@localhost:5432/identity_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (dev uses HS256 — prod needs RS256 key files)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Argon2id (OWASP recommended)
ARGON_MEMORY=19456
ARGON_ITERATIONS=2
ARGON_PARALLELISM=1
ARGON_SALT_LEN=16
ARGON_KEY_LEN=32

# CORS
ALLOWED_ORIGIN_WEB=http://localhost:3000
ALLOWED_ORIGIN_ADMIN=http://localhost:3002

# OAuth (fill in dev credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

BASE_URL=http://localhost:3001
