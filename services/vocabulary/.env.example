# vocabulary-service environment variables
# Copy to .env and fill in values

ENV=development
PORT=3004
VERSION=dev

# PostgreSQL (vocabulary_db)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vocabulary_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9094
KAFKA_ENABLED=false

# Identity service (for JWKS public key fetch)
IDENTITY_SERVICE_URL=http://localhost:3001

# CORS whitelist (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info

# OpenTelemetry
OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317

# Anki import max file size (bytes), default 10MB
ANKI_MAX_SIZE_BYTES=10485760
