# OmniLingo Web — local development environment
# Copy this to .env.local and fill in your values

# web-bff GraphQL endpoint
NEXT_PUBLIC_BFF_URL=http://localhost:4000/graphql

# identity-service direct endpoint (auth calls bypass BFF)
IDENTITY_SERVICE_URL=http://localhost:3001

# Next.js public URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
