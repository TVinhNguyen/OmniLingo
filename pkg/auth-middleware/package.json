{
  "name": "@omnilingo/auth-middleware",
  "version": "0.1.0",
  "description": "Shared JWKS-based JWT verification middleware for OmniLingo Node-TS services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
