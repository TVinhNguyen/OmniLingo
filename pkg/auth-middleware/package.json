    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "fastify": ">=4.0.0"
  },
  "dependencies": {
    "fastify-plugin": "^4.5.1",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.5"
  },
  "license": "UNLICENSED",
