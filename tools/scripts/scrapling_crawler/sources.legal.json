{
  "global": {
    "user_agent": "OmniLingoBot/1.0 (+https://omnilingo.local)",
    "delay_seconds": 0.8,
    "max_pages_per_source": 8,
    "respect_robots_txt": true
  },
  "sources": [
    {
      "name": "wiktionary_english_lemmas_legal",
      "enabled": true,
      "start_urls": [
        "https://en.wiktionary.org/wiki/Category:English_lemmas"
      ],
      "allowed_domains": [
        "en.wiktionary.org"
      ],
      "link_selectors": {
        "item_links": ".mw-category a::attr(href)",
        "next_pages": ""
      },
      "detail_fields": {
        "word": {
          "type": "text",
          "selector": "#firstHeading::text"
        },
        "first_definition": {
          "type": "text",
          "selector": "#mw-content-text .mw-parser-output ol li::text"
        },
        "ipa": {
          "type": "text",
          "selector": "span.IPA::text"
        },
        "license": {
          "type": "const",
          "value": "CC BY-SA 4.0 (verify and attribute before production use)"
        },
        "attribution": {
          "type": "const",
          "value": "Source: Wiktionary contributors"
        }
      }
    }
  ]
}